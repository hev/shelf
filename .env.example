# hev layer gateway. deriveFromStore auth: the API key IS the upstream
# Turbopuffer key (1Password: layer-turbopuffer / field credential / vault
# mesh-staging). Copy to .env and fill in the key. .env is gitignored.
LAYER_GATEWAY_URL=https://aws-us-east-1.hevlayer.com
LAYER_GATEWAY_API_KEY=

