# hev layer gateway. The API key is a Layer-issued inbound key scoped to
# shelf-books; the hev search data/admin tokens stay upstream-only. Copy to .env
# and fill in the key. .env is gitignored.
LAYER_GATEWAY_URL=https://aws-us-east-1.hevlayer.com
LAYER_GATEWAY_API_KEY=

# Optional overrides (defaults shown):
# SHELF_NAMESPACE=shelf-books
# SHELF_EMBED_MODEL=BAAI/bge-small-en-v1.5
